{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolvePackageJsonExports": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "paths": {
      "@tracelite/db": ["./packages/db/src/index.ts"],
      "@tracelite/db/*": ["./packages/db/src/*"],
      "@tracelite/common": ["./packages/common/src/index.ts"],
      "@tracelite/common/*": ["./packages/common/src/*"]
    }
  }
}
